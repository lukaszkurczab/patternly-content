{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "sourceBatchId", "trackId", "familyId", "contentVersion", "taxonomyVersion", "declaredModes", "provenance", "items"],
  "properties": {
    "schemaVersion": { "const": "manual-source-v1" },
    "sourceBatchId": { "type": "string", "minLength": 1 },
    "trackId": { "type": "string", "minLength": 1 },
    "familyId": { "type": "string", "minLength": 1 },
    "contentVersion": { "type": "string", "minLength": 1 },
    "taxonomyVersion": { "type": "string", "minLength": 1 },
    "declaredModes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "provenance": { "type": "object" },
    "groups": { "type": "array" },
    "items": { "type": "array", "minItems": 1 }
  }
}
