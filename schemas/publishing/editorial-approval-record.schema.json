{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "editorial-approval-record-v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["approvalSchemaVersion", "approvalId", "reviewKind", "batchId", "familyId", "trackId", "primaryTaxonomyReference", "includedItems", "targetContentVersion", "reviewer", "reviewDate", "technicalValidationEvidenceId", "factualAndEditorialDefectsFound", "requiredCorrections", "finalDisposition"],
  "properties": {
    "approvalSchemaVersion": { "const": 1 }, "approvalId": { "type": "string", "minLength": 1 }, "reviewKind": { "const": "editorial" }, "batchId": { "type": "string", "minLength": 1 }, "familyId": { "type": "string", "minLength": 1 }, "trackId": { "type": "string", "minLength": 1 }, "primaryTaxonomyReference": { "type": "string", "minLength": 1 },
    "includedItems": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["itemId", "itemFingerprint"] } }, "targetContentVersion": { "type": "string", "minLength": 1 }, "reviewer": { "type": "string", "minLength": 1 }, "reviewDate": { "type": "string", "minLength": 1 }, "technicalValidationEvidenceId": { "type": "string", "minLength": 1 }, "factualAndEditorialDefectsFound": { "type": "array" }, "requiredCorrections": { "type": "array" }, "finalDisposition": { "enum": ["approved", "rejected"] }
  }
}
