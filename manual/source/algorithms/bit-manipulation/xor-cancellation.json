        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "xor_of_two",
            "text": "The XOR of the two unique values, not either value individually."
          },
          {
            "id": "first_unique",
            "text": "The first unique value."
          },
          {
            "id": "second_unique",
            "text": "The second unique value."
