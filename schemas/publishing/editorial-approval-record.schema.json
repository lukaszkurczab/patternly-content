{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "editorial-approval-record-v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["approvalSchemaVersion", "approvalId", "reviewKind", "batchId", "familyId", "trackId", "primaryTaxonomyReference", "includedItems", "reviewer", "reviewDate", "technicalValidationEvidenceId", "factualAndEditorialDefectsFound", "requiredCorrections", "finalDisposition"],
  "properties": {
    "approvalSchemaVersion": { "const": 1 }, "approvalId": { "type": "string", "minLength": 1 }, "reviewKind": { "const": "editorial" }, "batchId": { "type": "string", "minLength": 1 }, "familyId": { "type": "string", "minLength": 1 }, "trackId": { "type": "string", "minLength": 1 }, "primaryTaxonomyReference": { "type": "string", "minLength": 1 },
    "includedItems": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["itemId", "itemFingerprint"], "properties": { "itemId": { "type": "string", "minLength": 1 }, "itemFingerprint": { "type": "string", "minLength": 1 } } } }, "targetContentVersion": { "type": "string", "minLength": 1, "description": "Historical approval context only; it does not constrain reuse of an unchanged item fingerprint." }, "reviewer": { "type": "object", "additionalProperties": false, "required": ["kind", "id"], "properties": { "kind": { "const": "human_editor" }, "id": { "type": "string", "minLength": 1 } } }, "reviewDate": { "type": "string", "minLength": 1 }, "technicalValidationEvidenceId": { "type": "string", "minLength": 1 }, "factualAndEditorialDefectsFound": { "type": "array", "items": { "type": "string" } }, "requiredCorrections": { "type": "array", "items": { "type": "string" } }, "finalDisposition": { "enum": ["approved", "rejected"] }, "revoked": { "type": "boolean" }
  }
}
