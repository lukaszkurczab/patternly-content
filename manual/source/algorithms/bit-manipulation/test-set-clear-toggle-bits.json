    {
      "id": "alg-bits-manipulate-013",
      "prompt": "Which statements about clearing with complement are correct? Select all that apply.",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "multiple",
        "options": [
