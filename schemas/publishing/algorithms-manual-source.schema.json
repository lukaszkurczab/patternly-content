{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "algorithms-manual-source-v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "batchId", "trackId", "familyId", "contentVersion", "taxonomyVersion", "declaredModes", "taxonomy", "batchKind", "authoringProvenance", "items", "modeStructures"],
  "properties": {
    "schemaVersion": { "const": "algorithms-manual-source-v2" },
    "batchId": { "type": "string", "minLength": 1 }, "trackId": { "const": "algorithms" }, "familyId": { "const": "algorithms" },
    "contentVersion": { "type": "string", "minLength": 1 }, "taxonomyVersion": { "type": "string", "minLength": 1 },
    "declaredModes": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
    "taxonomy": { "type": "object", "required": ["roadmapNodeId", "primaryMentalUnitId", "patternFamilyId"] },
    "batchKind": { "enum": ["standard", "contrast"] }, "contrastMetadata": { "type": "object" },
    "authoringProvenance": { "type": "object", "required": ["author", "createdAt", "contentBatchId", "authoringMethod"] },
    "items": { "type": "array", "minItems": 1 }, "modeStructures": { "type": "object" }
  }
}
