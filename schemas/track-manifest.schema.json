{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["formatVersion", "trackId", "familyId", "contentVersion", "itemCount", "bankPath", "sha256"],
  "properties": {
    "formatVersion": { "const": 1 },
    "trackId": { "type": "string", "minLength": 1 },
    "familyId": { "type": "string", "minLength": 1 },
    "contentVersion": { "type": "string", "minLength": 1 },
    "itemCount": { "type": "integer", "minimum": 1 },
    "bankPath": { "type": "string", "minLength": 1 },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
