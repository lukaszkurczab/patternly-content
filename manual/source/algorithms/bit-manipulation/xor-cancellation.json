  "items": [
    {
      "id": "alg-bits-xor-001",
      "prompt": "What is x XOR x for any fixed-width bit pattern x?",
      "difficulty": "intro",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "zero",
            "text": "A word of all zeros."
          },
          {
            "id": "x",
            "text": "x."
          },
          {
            "id": "all_ones",
            "text": "A word of all ones."
          },
          {
            "id": "complement",
            "text": "The complement of x."
          }
        ],
        "acceptedOptionIds": [
          "zero"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Each bit XOR itself is zero.",
        "details": "This self-cancellation identity is the basis of pair cancellation.",
        "wrongOptionExplanationsByOptionId": {
          "x": "XOR with zero preserves x; XOR with itself cancels.",
          "all_ones": "Equal bits produce zero under XOR.",
          "complement": "Complement is XOR with an all-ones mask, not with x itself."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "apply_xor_cancellation",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "xor_cancellation",
        "problemArchetypeId": "find_unique_element"
      }
    },
    {
      "id": "alg-bits-xor-002",
      "prompt": "What is x XOR 0?",
      "difficulty": "intro",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "x",
            "text": "x."
          },
          {
            "id": "zero",
            "text": "0."
          },
          {
            "id": "complement",
            "text": "The complement of x."
          },
          {
            "id": "one",
            "text": "1."
          }
        ],
        "acceptedOptionIds": [
          "x"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Zero is the identity element for XOR.",
        "details": "At every position, bit XOR 0 equals the original bit.",
        "wrongOptionExplanationsByOptionId": {
          "zero": "Only x XOR x cancels to zero.",
          "complement": "XOR with zero leaves every bit unchanged.",
          "one": "There is no universal one result."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "apply_xor_cancellation",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "xor_cancellation",
        "problemArchetypeId": "find_unique_element"
      }
    },
    {
      "id": "alg-bits-xor-003",
      "prompt": "Why can XOR operands be reordered when proving pair cancellation?",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "commutative_associative",
            "text": "XOR is commutative and associative."
          },
          {
            "id": "numeric_sort",
            "text": "XOR automatically sorts numeric values."
          },
          {
            "id": "addition_rule",
            "text": "XOR is ordinary addition."
          },
          {
            "id": "same_width_only_order",
            "text": "Fixed width forces one evaluation order."
          }
        ],
        "acceptedOptionIds": [
          "commutative_associative"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Reordering and regrouping bring equal values next to each other conceptually.",
        "details": "Each equal pair cancels to zero, and the zero identities disappear.",
        "wrongOptionExplanationsByOptionId": {
          "numeric_sort": "No sorting occurs.",
          "addition_rule": "Carries make ordinary addition different.",
          "same_width_only_order": "Width fixes patterns but not XOR grouping."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "apply_xor_cancellation",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "xor_cancellation",
        "problemArchetypeId": "find_unique_element"
      }
    },
    {
      "id": "alg-bits-xor-004",
      "prompt": "Every array value appears exactly twice except one value that appears once. What does XOR of all values produce?",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "unique_value",
            "text": "The value that appears once."
          },
          {
            "id": "zero",
            "text": "Always zero."
          },
          {
            "id": "sum",
            "text": "The arithmetic sum of all values."
          },
          {
            "id": "largest",
            "text": "The largest value."
          }
        ],
        "acceptedOptionIds": [
          "unique_value"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Every duplicated bit pattern cancels with its equal partner.",
        "details": "The accumulator starts at zero, so the only uncancelled pattern is the unique value.",
        "wrongOptionExplanationsByOptionId": {
          "zero": "The unpaired value remains after pair cancellation.",
          "sum": "XOR does not propagate carries.",
          "largest": "Ordering is irrelevant to cancellation."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "apply_xor_cancellation",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "xor_cancellation",
        "problemArchetypeId": "find_unique_element"
      }
    },
    {
      "id": "alg-bits-xor-005",
      "prompt": "What is the XOR reduction of an empty sequence when the accumulator starts at zero?",
      "difficulty": "intro",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "zero",
            "text": "0."
          },
          {
            "id": "undefined",
            "text": "Always undefined."
          },
          {
            "id": "all_ones",
            "text": "An all-ones word."
          },
          {
            "id": "one",
            "text": "1."
          }
        ],
        "acceptedOptionIds": [
          "zero"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Zero is the neutral element for XOR reduction.",
        "details": "An empty reduction leaves the initial accumulator unchanged.",
        "wrongOptionExplanationsByOptionId": {
          "undefined": "The identity accumulator defines the result.",
          "all_ones": "That is not the XOR identity.",
          "one": "No input bit toggles the zero accumulator."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "apply_xor_cancellation",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "xor_cancellation",
        "problemArchetypeId": "find_unique_element"
      }
    },
    {
      "id": "alg-bits-xor-006",
      "prompt": "A value appears three times and every other value appears twice. What remains after XOR reduction?",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "triple_value",
            "text": "The value appearing three times."
          },
          {
            "id": "zero",
            "text": "Zero."
          },
          {
            "id": "twice_value",
            "text": "A value appearing twice."
          },
          {
            "id": "count_three",
            "text": "The number 3."
          }
        ],
        "acceptedOptionIds": [
          "triple_value"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "XOR preserves whether each identical pattern occurs an odd or even number of times.",
        "details": "Three copies reduce to one because two cancel and one remains.",
        "wrongOptionExplanationsByOptionId": {
          "zero": "Three is odd, so one copy remains after one pair cancels.",
          "twice_value": "Every even multiplicity cancels completely.",
          "count_three": "XOR reduction operates on bit patterns, not occurrence counts."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "apply_xor_cancellation",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "xor_cancellation",
        "problemArchetypeId": "find_unique_element"
      }
    },
    {
      "id": "alg-bits-xor-007",
      "prompt": "What is 5 XOR 3 in binary arithmetic?",
      "difficulty": "intro",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "value_6",
            "text": "6."
          },
          {
            "id": "value_8",
            "text": "8."
          },
          {
            "id": "value_2",
            "text": "2."
          },
          {
            "id": "value_15",
            "text": "15."
          }
        ],
        "acceptedOptionIds": [
          "value_6"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "0101 XOR 0011 equals 0110.",
        "details": "XOR is addition without carries at each bit, not general arithmetic addition.",
        "wrongOptionExplanationsByOptionId": {
          "value_8": "8 is ordinary addition, not XOR.",
          "value_2": "This is not the bitwise XOR of 0101 and 0011.",
          "value_15": "OR of these values is 7, and XOR is 6."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "apply_xor_cancellation",
        "secondarySkillAtomIds": [],
