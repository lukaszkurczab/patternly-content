{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "approvalIdentity", "sourceBatchId", "trackId", "contentVersion", "reviewKind", "itemIds"],
  "properties": {
    "schemaVersion": { "const": "manual-approval-v1" },
    "approvalIdentity": { "type": "string", "minLength": 1 },
    "sourceBatchId": { "type": "string", "minLength": 1 },
    "trackId": { "type": "string", "minLength": 1 },
    "contentVersion": { "type": "string", "minLength": 1 },
    "reviewKind": { "enum": ["editorial", "technical"] },
    "itemIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  }
}
