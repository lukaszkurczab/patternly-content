    {
      "id": "alg-bits-manipulate-015",
      "prompt": "Arrange the steps for testing zero-based bit k.",
      "difficulty": "foundational",
      "interaction": {
        "type": "ordering",
        "elements": [
          {
            "id": "validate_k",
            "text": "Confirm k is inside the declared word width."
          },
          {
            "id": "build_mask",
            "text": "Construct a one-hot mask with bit k set."
          },
          {
            "id": "and_word",
            "text": "AND the word with the mask."
          },
          {
            "id": "interpret",
            "text": "Treat a nonzero result as set and zero as clear."
