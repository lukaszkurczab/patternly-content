{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "algorithms-manual-source-v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "batchId", "trackId", "familyId", "contentVersion", "taxonomyVersion", "declaredModes", "taxonomy", "batchKind", "authoringProvenance", "items", "modeStructures"],
  "properties": {
    "schemaVersion": { "const": "algorithms-manual-source-v2" },
    "batchId": { "type": "string", "minLength": 1 },
    "trackId": { "const": "algorithms" },
    "familyId": { "const": "algorithms" },
    "contentVersion": { "type": "string", "minLength": 1 },
    "taxonomyVersion": { "type": "string", "minLength": 1 },
    "declaredModes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "taxonomy": { "type": "object", "additionalProperties": false, "required": ["roadmapNodeId", "primaryMentalUnitId", "patternFamilyId"], "properties": { "roadmapNodeId": { "type": "string", "minLength": 1 }, "primaryMentalUnitId": { "type": "string", "minLength": 1 }, "patternFamilyId": { "type": "string", "minLength": 1 } } },
    "batchKind": { "enum": ["standard", "contrast"] },
    "contrastMetadata": { "type": "object", "additionalProperties": false, "required": ["contrastedMentalUnitIds", "falseHeuristicId", "transferBoundary"], "properties": { "contrastedMentalUnitIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }, "falseHeuristicId": { "type": "string", "minLength": 1 }, "transferBoundary": { "type": "string", "minLength": 1 } } },
    "authoringProvenance": { "type": "object", "additionalProperties": false, "required": ["author", "createdAt", "contentBatchId", "authoringMethod"], "properties": { "author": { "type": "string", "minLength": 1 }, "createdAt": { "type": "string", "minLength": 1 }, "contentBatchId": { "type": "string", "minLength": 1 }, "authoringMethod": { "const": "independently_authored" } } },
    "items": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["id", "prompt", "interaction", "scoringContract", "feedback", "taxonomy"], "properties": { "id": { "type": "string", "minLength": 1 }, "prompt": { "type": "string", "minLength": 1 }, "constraints": { "type": "string", "minLength": 1 }, "difficulty": { "type": "string", "minLength": 1 }, "interaction": { "type": "object", "required": ["type"] }, "scoringContract": { "type": "object", "required": ["type"] }, "feedback": { "type": "object", "required": ["reason", "details"], "properties": { "reason": { "type": "string", "minLength": 1 }, "details": { "type": "string", "minLength": 1 }, "wrongOptionExplanationsByOptionId": { "type": "object" }, "omittedCorrectExplanationsByOptionId": { "type": "object" } } }, "taxonomy": { "type": "object", "additionalProperties": false, "required": ["primarySkillAtomId", "secondarySkillAtomIds", "learningStage"], "properties": { "primarySkillAtomId": { "type": "string", "minLength": 1 }, "secondarySkillAtomIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }, "learningStage": { "type": "string", "minLength": 1 }, "patternVariantId": { "type": "string", "minLength": 1 }, "problemArchetypeId": { "type": "string", "minLength": 1 } } }, "sourceOverrides": { "type": "array", "items": { "type": "object", "required": ["sourceId", "publisher", "title", "locator", "retrievedAt"], "properties": { "sourceId": { "type": "string", "minLength": 1 }, "publisher": { "type": "string", "minLength": 1 }, "title": { "type": "string", "minLength": 1 }, "locator": { "type": "string", "minLength": 1 }, "retrievedAt": { "type": "string", "minLength": 1 } } } } } } },
    "modeStructures": { "type": "object", "additionalProperties": false, "required": ["practiceBlueprints", "recognitionSets", "contrastSets", "interleavedScopes", "compatibilitySets", "simulationPools", "simulationProfiles"], "properties": {
      "practiceBlueprints": { "type": "array", "items": { "type": "object", "required": ["blueprintId", "blueprintVersion", "modeId", "requestedLengths", "defaultRequestedLength", "shortening", "minimumActualLength", "composition"], "properties": { "blueprintId": { "type": "string", "minLength": 1 }, "blueprintVersion": { "type": "string", "minLength": 1 }, "modeId": { "type": "string", "minLength": 1 }, "requestedLengths": { "type": "array", "minItems": 1, "items": { "type": "integer" } }, "defaultRequestedLength": { "type": "integer" }, "shortening": { "type": "string", "minLength": 1 }, "minimumActualLength": { "type": "integer" }, "composition": { "type": "object", "required": ["kind", "ids"], "properties": { "kind": { "type": "string", "minLength": 1 }, "ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } } } } } } },
      "recognitionSets": { "type": "array", "items": { "type": "object", "required": ["setId", "setVersion", "taxonomyScope", "legalLearningStages", "itemIds"], "properties": { "setId": { "type": "string", "minLength": 1 }, "setVersion": { "type": "string", "minLength": 1 }, "taxonomyScope": { "type": "object" }, "legalLearningStages": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }, "itemIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } } } } },
      "contrastSets": { "type": "array", "items": { "type": "object", "required": ["setId", "setVersion", "primaryMentalUnitId", "contrastedMentalUnitIds", "falseHeuristicId", "transferBoundary", "itemIds"], "properties": { "setId": { "type": "string", "minLength": 1 }, "setVersion": { "type": "string", "minLength": 1 }, "primaryMentalUnitId": { "type": "string", "minLength": 1 }, "contrastedMentalUnitIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }, "falseHeuristicId": { "type": "string", "minLength": 1 }, "transferBoundary": { "type": "string", "minLength": 1 }, "itemIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } } } } },
      "interleavedScopes": { "type": "array", "items": { "type": "object", "required": ["scopeId", "scopeVersion", "mentalUnitIds", "itemIds", "legalLearningStages"], "properties": { "scopeId": { "type": "string", "minLength": 1 }, "scopeVersion": { "type": "string", "minLength": 1 }, "mentalUnitIds": { "type": "array", "minItems": 2, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }, "itemIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }, "legalLearningStages": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } } } },
      "compatibilitySets": { "type": "array", "items": { "type": "object", "required": ["id", "version", "relation", "direction", "sourceItemIds", "targetItemIds", "relationMetadata"], "properties": { "id": { "type": "string", "minLength": 1 }, "version": { "type": "string", "minLength": 1 }, "relation": { "enum": ["same_mechanism", "reviewed_variant", "compatible_contrast", "repair"] }, "direction": { "enum": ["symmetric", "directed"] }, "sourceItemIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }, "targetItemIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }, "relationMetadata": { "type": "object" } } } },
      "simulationPools": { "type": "array", "items": { "type": "object", "required": ["poolId", "poolVersion", "itemIds"], "properties": { "poolId": { "type": "string", "minLength": 1 }, "poolVersion": { "type": "string", "minLength": 1 }, "itemIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } } } },
      "simulationProfiles": { "type": "array", "items": { "type": "object", "required": ["profileId", "profileVersion", "profileKind", "totalOccurrences", "foregroundDurationMs", "poolId", "distributions", "selectionPolicy", "provenance"], "properties": { "profileId": { "type": "string", "minLength": 1 }, "profileVersion": { "type": "string", "minLength": 1 }, "profileKind": { "const": "internal_learning_profile" }, "totalOccurrences": { "const": 40 }, "foregroundDurationMs": { "const": 2700000 }, "poolId": { "type": "string", "minLength": 1 }, "distributions": { "type": "array", "items": { "type": "object", "required": ["dimension", "buckets"], "properties": { "dimension": { "type": "string", "minLength": 1 }, "buckets": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["valueId", "minimum", "target", "maximum"], "properties": { "valueId": { "type": "string", "minLength": 1 }, "minimum": { "type": "integer" }, "target": { "type": "integer" }, "maximum": { "type": "integer" } } } } } } }, "selectionPolicy": { "type": "object", "required": ["uniqueItems", "replacement", "deterministic", "algorithmVersion"], "properties": { "uniqueItems": { "const": true }, "replacement": { "const": false }, "deterministic": { "const": true }, "algorithmVersion": { "const": "sha256-ranked-constraints-v1" } } }, "provenance": { "type": "object", "required": ["authority", "approvedBy", "approvedAt", "rationale"], "properties": { "authority": { "const": "patternly_product" }, "approvedBy": { "type": "string", "minLength": 1 }, "approvedAt": { "type": "string", "minLength": 1 }, "rationale": { "type": "string", "minLength": 1 } } } } } }
    } }
  }
}
