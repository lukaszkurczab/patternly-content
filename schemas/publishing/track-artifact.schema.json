{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "familyId", "trackId", "contentVersion", "taxonomyVersion", "declaredModes", "approvalCoverage", "checksumSha256", "sourceRepositoryCommit", "artifactBytes"],
  "properties": { "schemaVersion": { "const": "published-bank-v1" }, "familyId": { "type": "string" }, "trackId": { "type": "string" }, "contentVersion": { "type": "string" }, "taxonomyVersion": { "type": "string" }, "declaredModes": { "type": "array" }, "approvalCoverage": { "type": "object" }, "checksumSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "sourceRepositoryCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" }, "artifactBytes": { "type": "string" } }
}
