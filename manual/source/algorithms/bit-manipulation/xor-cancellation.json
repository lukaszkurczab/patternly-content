      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "XOR is independent parity addition modulo two at every position.",
        "details": "The lack of carries explains both its cancellation property and its information loss.",
        "wrongOptionExplanationsByOptionId": {
          "exact_count": "Only parity is preserved."
        },
        "omittedCorrectExplanationsByOptionId": {
          "odd_one": "Each one toggles the result.",
