{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["formatVersion", "trackId", "familyId", "contentVersion", "groups", "items"],
  "properties": {
    "formatVersion": { "const": 1 },
    "trackId": { "const": "algorithms" },
    "familyId": { "const": "algorithms" },
    "contentVersion": { "type": "string", "minLength": 1 },
    "groups": { "type": "array", "minItems": 1 },
    "items": { "type": "array", "minItems": 1 }
  }
}
