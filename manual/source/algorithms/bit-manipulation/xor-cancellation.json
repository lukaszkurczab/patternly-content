    {
      "id": "alg-bits-xor-012",
      "prompt": "Which XOR identities are correct? Select all that apply.",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "multiple",
        "options": [
          {
            "id": "self_zero",
            "text": "x XOR x = 0."
          },
          {
            "id": "zero_identity",
            "text": "x XOR 0 = x."
          },
          {
            "id": "commutative",
            "text": "x XOR y = y XOR x."
          },
          {
            "id": "idempotent",
            "text": "x XOR x = x."
          }
