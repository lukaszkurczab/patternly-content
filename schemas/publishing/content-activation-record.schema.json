{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "content-activation-record-v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["activationSchemaVersion", "activationId", "trackId", "familyId", "contentVersion", "taxonomyVersion", "itemCoverage"],
  "properties": { "activationSchemaVersion": { "const": 1 }, "activationId": { "type": "string", "minLength": 1 }, "trackId": { "type": "string", "minLength": 1 }, "familyId": { "type": "string", "minLength": 1 }, "contentVersion": { "type": "string", "minLength": 1 }, "taxonomyVersion": { "type": "string", "minLength": 1 }, "itemCoverage": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["itemId", "itemFingerprint", "approvalId"] } } }
}
