  "items": [
    {
      "id": "alg-dpintro-diagnose-01-overlap-not-complete-proof",
      "prompt": "A solution note says, “The recursion repeats calls, so storing by index makes it a correct DP.” What is the best diagnosis?",
      "constraints": [
        "The recurrence also carries a remaining target that changes future choices.",
        "No proof of the index-only key is given."
      ],
      "difficulty": "intermediate",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "insufficient_state_claim",
            "text": "The conclusion is unsupported: overlap exists, but the cache key omits a future-relevant state component and can merge different subproblems."
          },
          {
            "id": "overlap_enough",
            "text": "The reasoning is complete because any overlap guarantees a correct index-only DP."
          },
          {
            "id": "memo_speed_only",
            "text": "The only possible issue is that memoization may be slower than tabulation."
          }
        ],
        "acceptedOptionIds": [
          "insufficient_state_claim"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Repeated work is only one DP signal; the proposed index key is invalid because remaining target changes the unresolved problem.",
        "details": "A sound DP argument connects state meaning, complete identity, transition, bases, and evaluation. Here two calls at the same index can have different remaining targets and therefore different legal completions. Caching them together can return an answer from the wrong subproblem. The presence of overlap does not repair an incomplete state or prove the rest of the model.",
        "wrongOptionExplanationsByOptionId": {
          "overlap_enough": "Overlap identifies potential reuse, not which arguments define equality or whether the recurrence is correct.",
          "memo_speed_only": "Performance is secondary; the omitted remaining target is a correctness defect in state identity."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "diagnose_incomplete_dp_state_or_transition",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "memoization",
        "problemArchetypeId": "count_ways"
      }
    },
    {
      "id": "alg-dpintro-diagnose-02-small-counterexample-state",
      "prompt": "A solver caches choose(i, remainingCapacity) only by i. Which test most decisively exposes the bug?",
      "constraints": [
        "At index i, the next item has weight 5 and positive value.",
        "Both states are reachable."
      ],
      "difficulty": "advanced",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "different_indices",
            "text": "Compare i and i + 1 with the same capacity."
          },
          {
            "id": "large_random",
            "text": "Run one large random input and check whether the final answer looks plausible."
          },
          {
            "id": "capacity_collision",
            "text": "Compare calls at the same i with capacities 4 and 5; the take branch is illegal in one and legal in the other."
          }
        ],
        "acceptedOptionIds": [
          "capacity_collision"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "The capacities 4 and 5 create different legal futures under the same index key, directly refuting state sufficiency.",
        "details": "A diagnostic counterexample should isolate the omitted variable. At the same i, crossing the next item's weight threshold changes whether taking is possible, so the two correct suffix values can differ. An index-only cache cannot store both and will reuse whichever is computed first. This collision proof is smaller and more decisive than broad random testing.",
        "wrongOptionExplanationsByOptionId": {
          "different_indices": "Those calls already have different keys, so they do not demonstrate a collision in the proposed cache.",
          "large_random": "A plausible final output may miss the defect; a minimal colliding pair directly proves the key merges nonequivalent states."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "diagnose_incomplete_dp_state_or_transition",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "two_dimensional_dp",
        "problemArchetypeId": "choose_or_skip"
      }
    },
    {
      "id": "alg-dpintro-diagnose-03-performance-versus-correctness",
      "prompt": "A memoized alignment solver returns correct values but is slower than a tabulation on dense inputs and can exhaust the recursion stack. What is the diagnosis?",
      "constraints": [
        "The state, cache key, transition, and base cases have been verified correct."
      ],
      "difficulty": "intermediate",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "tabulation_only_dp",
            "text": "The method is not dynamic programming because only a bottom-up table can evaluate a dense state space correctly."
          },
          {
            "id": "implementation_tradeoff",
            "text": "The DP model is correct; dense reachability exposes top-down call, lookup, and stack overhead."
          },
          {
            "id": "state_bug",
            "text": "The state is incomplete because any correct memoized implementation must outperform an equivalent tabulation."
          }
        ],
        "acceptedOptionIds": [
          "implementation_tradeoff"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Correctness and evaluation cost are separate dimensions; memoization is valid here but not the best operational choice.",
        "details": "The solver still evaluates each state consistently and returns the intended result. Dense reachability means top-down skips little work, while recursive calls, cache operations, and stack depth add costs that iterative loops may avoid. The repair is an implementation decision, not a new state or transition. Review should not mislabel every slower memoized solution as incorrect.",
        "wrongOptionExplanationsByOptionId": {
          "state_bug": "Runtime does not determine state sufficiency; verified correct outputs and state invariants separate this from a semantic defect.",
          "tabulation_only_dp": "Memoized top-down evaluation is a valid DP implementation when it caches complete states and uses a correct recurrence."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "diagnose_incomplete_dp_state_or_transition",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "memoization",
        "problemArchetypeId": "sequence_alignment_intro"
      }
    },
    {
      "id": "alg-dpintro-diagnose-04-direction-defect",
      "prompt": "A 0/1 capacity DP uses the correct one-array formula but processes capacity from low to high. Outputs match an unbounded-choice solution. What is the primary defect?",
      "constraints": [
        "Each item should be used at most once.",
        "The take term reads dp[c - w]."
      ],
      "difficulty": "intermediate",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "iteration_alias",
            "text": "The loop reads current-item values after overwrite, changing the intended previous-layer dependency."
          },
          {
            "id": "base_only",
            "text": "The base dp[0] must be wrong because update direction cannot change a recurrence's item multiplicity."
          },
          {
            "id": "overlap_missing",
            "text": "The recurrence lacks overlapping subproblems, so the one-array formula cannot represent dynamic programming."
          }
        ],
        "acceptedOptionIds": [
          "iteration_alias"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Ascending in-place updates alias the previous-item dependency with the current layer and permit repeated use.",
        "details": "The mathematical 0/1 recurrence reads values from the prior item layer. A descending loop preserves those values until consumption; an ascending loop overwrites lower capacities first and then reads them as if they were prior-layer states. The formula may look identical in code, but its operational meaning has changed. This is an iteration-order defect, not a base or overlap defect.",
        "wrongOptionExplanationsByOptionId": {
          "base_only": "The observed repeated use follows directly from ascending in-place updates even when dp[0] is correct.",
          "overlap_missing": "Capacity states are reused; the problem is which version is read, not the absence of overlap."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "diagnose_incomplete_dp_state_or_transition",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "state_compression",
        "problemArchetypeId": "choose_or_skip"
      }
    },
    {
      "id": "alg-dpintro-diagnose-05-compression-output-defect",
      "prompt": "A two-row DP returns the correct optimum length, but the API also requires one optimal alignment and no reconstruction plan exists. How should review classify it?",
      "constraints": [
        "All value tests pass.",
        "The discarded rows contained the ordinary predecessor trace."
      ],
      "difficulty": "advanced",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "fully_correct",
            "text": "The implementation is complete because a correct optimum scalar is sufficient evidence of an optimal alignment."
          },
          {
            "id": "wrong_recurrence",
            "text": "The recurrence is incorrect because any valid alignment recurrence must retain the full value table."
          },
          {
            "id": "incomplete_output",
            "text": "The value computation is correct, but the required witness has no retained or recomputable trace."
          }
        ],
        "acceptedOptionIds": [
          "incomplete_output"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "The optimized storage satisfies only the value subproblem, not the complete witness-producing contract.",
        "details": "Review should separate forward value correctness from output completeness. Rolling rows can preserve every dependency needed to compute the optimum while discarding the history used to recover an alignment. Without parent data, checkpoints, or recomputation, the API cannot deliver its required witness. This is a compression/output-boundary defect, not proof that the recurrence itself is wrong.",
        "wrongOptionExplanationsByOptionId": {
          "fully_correct": "The stated API requires a witness, so satisfying only a narrower scalar contract is insufficient.",
          "wrong_recurrence": "The value recurrence can remain correct; the defect is information loss relative to reconstruction."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "diagnose_incomplete_dp_state_or_transition",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "state_compression",
        "problemArchetypeId": "sequence_alignment_intro"
      }
    },
    {
      "id": "alg-dpintro-diagnose-06-smallest-failing-state",
      "prompt": "Order a disciplined DP mistake review using a small counterexample and an uncompressed reference.",
      "constraints": [
        "The reference recurrence and expected state meanings are trusted.",
        "The implementation exposes state values or a trace."
      ],
      "difficulty": "advanced",
      "interaction": {
        "type": "ordering",
        "elements": [
          {
            "id": "minimize_input",
            "text": "Reduce the failing input while preserving the wrong result."
          },
          {
            "id": "compare_bases",
            "text": "Verify every reachable base and impossible-state sentinel on that input."
          },
          {
            "id": "find_first_wrong",
            "text": "Compare states in dependency order and identify the first value that diverges."
          },
          {
            "id": "classify_cause",
            "text": "Inspect that state's inputs, transition, and update versions to classify the defect before changing code."
          }
        ],
        "canonicalOrder": [
          "minimize_input",
          "compare_bases",
          "find_first_wrong",
          "classify_cause"
        ],
        "scoringMethod": "adjacent_relations"
      },
      "scoringContract": {
        "type": "ordering",
        "maxPoints": 3
      },
      "feedback": {
        "reason": "The first divergent state is the narrowest point at which a wrong base, transition, or dependency version can enter the computation.",
        "details": "A smaller counterexample reduces the number of states and branches to inspect. Bases are checked first because every later value depends on them. Comparing in dependency order then finds the earliest incorrect state, whose dependencies should still match the reference; that sharply identifies whether the local transition or update version is wrong. Editing before classification can mask one defect with another."
      },
      "taxonomy": {
        "primarySkillAtomId": "diagnose_incomplete_dp_state_or_transition",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "tabulation",
        "problemArchetypeId": "optimize_prefix_or_suffix"
      }
    },
    {
      "id": "alg-dpintro-diagnose-07-diagnostic-ownership-transfer",
      "prompt": "Select all defect-to-owner mappings that are correct.",
      "constraints": [
        "Choose every correct mapping.",
        "Each defect is described at its first violated contract."
      ],
      "difficulty": "advanced",
      "interaction": {
        "type": "choice",
        "selectionMode": "multiple",
        "options": [
          {
            "id": "state_owner",
            "text": "Two histories share a cache key but have different legal futures → define_dp_state."
          },
          {
            "id": "order_owner",
            "text": "A one-row update reads a current-layer value where the recurrence requires a previous layer → iteration_order."
          },
          {
            "id": "base_as_transition",
            "text": "A blocked origin is seeded with one path → define_transition."
          },
          {
            "id": "reconstruct_as_overlap",
            "text": "The optimum value is correct but no witness can be recovered → recognize_overlapping_subproblems."
          }
        ],
        "acceptedOptionIds": [
          "state_owner",
          "order_owner"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Diagnosis should name the first broken contract and route the repair to its owning mental unit.",
        "details": "State collisions are repaired by defining a sufficient state or key. Wrong-layer reads arise from an evaluation order that does not preserve the recurrence's dependency versions. A blocked-origin seed is a base feasibility error, while a missing witness is a reconstruction/storage-output issue. This ownership discipline keeps mistake review diagnostic rather than turning it into a second, overlapping version of every DP lesson.",
        "wrongOptionExplanationsByOptionId": {
          "base_as_transition": "The first violated contract is feasibility of the terminal/start state, so base_cases_and_initialization owns the repair.",
          "reconstruct_as_overlap": "The defect concerns preserved predecessor evidence and output reconstruction, not whether equal states recur."
        },
        "omittedCorrectExplanationsByOptionId": {
          "state_owner": "A cache collision between nonequivalent histories is a state-sufficiency defect.",
          "order_owner": "Reading the wrong logical layer is an iteration/update-order defect."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "diagnose_incomplete_dp_state_or_transition",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "two_dimensional_dp",
        "problemArchetypeId": "grid_path_dp"
      }
    }
  ],
