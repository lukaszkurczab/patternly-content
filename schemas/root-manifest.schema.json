{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["formatVersion", "publishedAt", "tracks"],
  "properties": {
    "formatVersion": { "const": 1 },
    "publishedAt": { "type": "string", "format": "date-time" },
    "tracks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["trackId", "familyId", "contentVersion", "manifestPath"],
        "properties": {
          "trackId": { "type": "string", "minLength": 1 },
          "familyId": { "type": "string", "minLength": 1 },
          "contentVersion": { "type": "string", "minLength": 1 },
          "manifestPath": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
