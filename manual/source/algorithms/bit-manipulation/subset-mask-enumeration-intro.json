  "items": [
    {
      "id": "alg-bits-subsets-001",
      "prompt": "How many index subsets exist for n distinct indexed elements?",
      "difficulty": "intro",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "two_power_n",
            "text": "2^n."
          },
          {
            "id": "n",
            "text": "n."
          },
          {
            "id": "n_factorial",
            "text": "n!."
          },
          {
            "id": "n_squared",
            "text": "n^2."
          }
        ],
        "acceptedOptionIds": [
          "two_power_n"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Every one of n positions contributes a binary membership choice.",
        "details": "The resulting masks range over all n-bit patterns.",
        "wrongOptionExplanationsByOptionId": {
          "n": "Each element has an independent include/exclude choice.",
          "n_factorial": "That counts orderings, not subsets.",
          "n_squared": "Subset count grows exponentially."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "enumerate_subset_by_bitmask",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "subset_mask",
        "problemArchetypeId": "enumerate_subsets_by_mask"
      }
    },
    {
      "id": "alg-bits-subsets-002",
      "prompt": "Which mask range enumerates every subset of n indexed elements exactly once?",
      "difficulty": "intro",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "zero_to_two_n_minus_one",
            "text": "0 through 2^n - 1, inclusive."
          },
          {
            "id": "one_to_two_n",
            "text": "1 through 2^n, inclusive."
          },
          {
            "id": "zero_to_n_minus_one",
            "text": "0 through n - 1."
          },
          {
            "id": "zero_to_n_factorial",
            "text": "0 through n! - 1."
          }
        ],
        "acceptedOptionIds": [
          "zero_to_two_n_minus_one"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Every n-bit pattern is one subset encoding.",
        "details": "Zero represents the empty subset and the all-ones n-bit mask represents the full subset.",
        "wrongOptionExplanationsByOptionId": {
          "one_to_two_n": "This omits the empty mask and includes a mask needing bit n.",
          "zero_to_n_minus_one": "There are 2^n masks, not n.",
          "zero_to_n_factorial": "Permutation count is unrelated."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "enumerate_subset_by_bitmask",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "subset_mask",
        "problemArchetypeId": "enumerate_subsets_by_mask"
      }
    },
    {
      "id": "alg-bits-subsets-003",
      "prompt": "What subset does mask 0 represent?",
      "difficulty": "intro",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "empty",
            "text": "The empty subset."
          },
          {
            "id": "first_only",
            "text": "Only element 0."
          },
          {
            "id": "full",
            "text": "The full subset."
          },
          {
            "id": "invalid",
            "text": "An invalid subset."
          }
        ],
        "acceptedOptionIds": [
          "empty"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "No set bit selects any indexed element.",
        "details": "The zero mask is the identity boundary of subset enumeration.",
        "wrongOptionExplanationsByOptionId": {
          "first_only": "That would require bit 0 set.",
          "full": "The full subset uses all n low bits set.",
          "invalid": "The empty subset is a valid member of the power set."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "enumerate_subset_by_bitmask",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "subset_mask",
        "problemArchetypeId": "enumerate_subsets_by_mask"
      }
    },
    {
      "id": "alg-bits-subsets-004",
      "prompt": "What mask represents the full subset of n elements when bits 0 through n - 1 map to those elements?",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "all_low_ones",
            "text": "(1 shifted left by n) - 1."
          },
          {
            "id": "one_shift_n",
            "text": "1 shifted left by n."
          },
          {
            "id": "zero",
            "text": "0."
          },
          {
            "id": "n",
            "text": "The numeric value n."
          }
        ],
        "acceptedOptionIds": [
          "all_low_ones"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "The full subset needs every one of the n low positions set.",
        "details": "The value 2^n - 1 has exactly that pattern.",
        "wrongOptionExplanationsByOptionId": {
          "one_shift_n": "That sets bit n, outside the n element positions.",
          "zero": "Zero represents the empty subset.",
          "n": "The full mask depends exponentially on n."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "enumerate_subset_by_bitmask",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "subset_mask",
        "problemArchetypeId": "enumerate_subsets_by_mask"
      }
    },
    {
      "id": "alg-bits-subsets-005",
      "prompt": "If bit position i maps to elements[i], when is that element included in the subset encoded by mask?",
      "difficulty": "intro",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "bit_set",
            "text": "When mask AND (1 shifted left by i) is nonzero."
          },
          {
            "id": "bit_clear",
            "text": "When that AND result is zero."
          },
          {
            "id": "mask_equal_i",
            "text": "Only when mask numerically equals i."
          },
          {
            "id": "i_even",
            "text": "Only when i is even."
          }
        ],
        "acceptedOptionIds": [
          "bit_set"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Subset decoding is a membership test at each mapped position.",
        "details": "A one bit means included and a zero bit means excluded.",
        "wrongOptionExplanationsByOptionId": {
          "bit_clear": "Zero means the position is not selected.",
          "mask_equal_i": "A mask can select many positions.",
          "i_even": "Parity of the index is irrelevant."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "enumerate_subset_by_bitmask",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "subset_mask",
        "problemArchetypeId": "enumerate_subsets_by_mask"
      }
    },
    {
      "id": "alg-bits-subsets-006",
      "prompt": "For elements [A, B, C, D], which subset is encoded by mask 1010 when bit 0 maps to A?",
      "difficulty": "intro",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "b_d",
            "text": "{B, D}."
          },
          {
            "id": "a_c",
            "text": "{A, C}."
          },
          {
            "id": "a_b_c",
            "text": "{A, B, C}."
          },
          {
            "id": "c_d",
            "text": "{C, D}."
          }
        ],
        "acceptedOptionIds": [
          "b_d"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Mask bits 1 and 3 are set.",
        "details": "Those positions map to B and D.",
        "wrongOptionExplanationsByOptionId": {
          "a_c": "That would be mask 0101.",
          "a_b_c": "Bit positions 0 and 2 are zero.",
          "c_d": "Bit 2 is zero and bit 1 is set."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "enumerate_subset_by_bitmask",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "subset_mask",
        "problemArchetypeId": "enumerate_subsets_by_mask"
      }
    },
    {
      "id": "alg-bits-subsets-007",
      "prompt": "The input values are [X, X] at two distinct indices. How many index subsets do two bits encode?",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "four_index_subsets",
            "text": "Four index subsets, though some materialized value lists may be equal."
          },
          {
            "id": "three",
            "text": "Three subsets because equal values merge automatically."
          },
          {
            "id": "two",
            "text": "Two subsets."
          },
          {
            "id": "one",
            "text": "One subset because both values are equal."
          }
        ],
        "acceptedOptionIds": [
          "four_index_subsets"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Bitmask enumeration naturally enumerates subsets of indexed occurrences.",
        "details": "If the result contract wants value-distinct subsets, separate duplicate control is required.",
        "wrongOptionExplanationsByOptionId": {
          "three": "Masks encode positions, not deduplicated values.",
          "two": "Each of two positions has an independent choice.",
          "one": "Value equality does not erase index identity."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "enumerate_subset_by_bitmask",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "subset_mask",
        "problemArchetypeId": "enumerate_subsets_by_mask"
      }
    },
    {
      "id": "alg-bits-subsets-008",
      "prompt": "Does increasing numeric mask order enumerate subsets by increasing subset size?",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "no",
            "text": "No. Numeric order follows binary value, not popcount."
          },
          {
            "id": "yes_always",
            "text": "Yes. Every later mask contains more set bits."
          },
          {
            "id": "only_even_n",
            "text": "Only when n is even."
          },
          {
            "id": "only_sorted_values",
            "text": "Only when input values are sorted."
          }
        ],
        "acceptedOptionIds": [
          "no"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Numeric mask order changes membership according to binary counting.",
        "details": "Subset size can increase or decrease between consecutive masks.",
        "wrongOptionExplanationsByOptionId": {
          "yes_always": "For example, 0011 has two bits and 0100 has one.",
          "only_even_n": "Parity of n does not fix the ordering.",
          "only_sorted_values": "Mask order is independent of element values."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "enumerate_subset_by_bitmask",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "subset_mask",
        "problemArchetypeId": "enumerate_subsets_by_mask"
      }
    },
    {
      "id": "alg-bits-subsets-009",
      "prompt": "Why must the representation provide at least n usable mask bits to encode subsets of n indexed elements in one word?",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "one_per_element",
            "text": "Each element needs its own independent membership position."
          },
          {
            "id": "numeric_value",
            "text": "The largest element value determines width."
          },
          {
            "id": "sort_order",
            "text": "Each sorted rank needs two bits."
          },
          {
            "id": "empty_subset",
            "text": "Only the empty subset requires n bits."
          }
        ],
        "acceptedOptionIds": [
          "one_per_element"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "A one-word subset mask allocates one boolean slot per element index.",
        "details": "If n exceeds usable width, a larger or multiword representation is needed.",
        "wrongOptionExplanationsByOptionId": {
          "numeric_value": "Width depends on element count, not values.",
          "sort_order": "One boolean membership bit is sufficient.",
          "empty_subset": "Every subset uses the same n-position mapping."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "enumerate_subset_by_bitmask",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "subset_mask",
        "problemArchetypeId": "enumerate_subsets_by_mask"
      }
    },
    {
      "id": "alg-bits-subsets-010",
      "prompt": "Which statements about n-bit subset masks are correct? Select all that apply.",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "multiple",
        "options": [
          {
            "id": "zero_empty",
            "text": "Mask 0 encodes the empty subset."
          },
          {
            "id": "full_all_ones",
            "text": "Mask 2^n - 1 encodes the full subset."
          },
          {
            "id": "bit_membership",
            "text": "Bit i records membership of indexed element i."
          },
          {
            "id": "numeric_order_size",
            "text": "Numeric mask order is the same as nondecreasing subset-size order."
          }
        ],
        "acceptedOptionIds": [
          "zero_empty",
          "full_all_ones",
          "bit_membership"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Subset masks are positional membership encodings.",
        "details": "Enumeration order and subset-cardinality order are different concerns.",
        "wrongOptionExplanationsByOptionId": {
          "numeric_order_size": "Binary counting does not preserve popcount order."
        },
        "omittedCorrectExplanationsByOptionId": {
          "zero_empty": "No positions are selected.",
          "full_all_ones": "All n low bits are set.",
          "bit_membership": "This is the encoding contract."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "enumerate_subset_by_bitmask",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "subset_mask",
        "problemArchetypeId": "enumerate_subsets_by_mask"
      }
    },
    {
      "id": "alg-bits-subsets-011",
      "prompt": "Which tests are important for subset-mask enumeration? Select all that apply.",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "multiple",
        "options": [
          {
            "id": "n_zero",
            "text": "n = 0, which should yield one empty subset."
          },
          {
            "id": "n_one",
            "text": "n = 1, which should yield empty and singleton subsets."
          },
          {
            "id": "full_mask",
            "text": "The final all-ones mask."
          },
          {
            "id": "only_middle",
            "text": "Only one nonzero middle mask."
          }
        ],
        "acceptedOptionIds": [
          "n_zero",
          "n_one",
          "full_mask"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "The empty-domain identity and both mask extremes expose off-by-one errors.",
        "details": "A middle mask alone cannot prove complete enumeration.",
        "wrongOptionExplanationsByOptionId": {
          "only_middle": "This does not test empty or full boundaries."
        },
        "omittedCorrectExplanationsByOptionId": {
          "n_zero": "The power set of the empty set contains the empty set.",
          "n_one": "This tests both mask boundaries.",
          "full_mask": "It verifies inclusion of every element."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "enumerate_subset_by_bitmask",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "subset_mask",
        "problemArchetypeId": "enumerate_subsets_by_mask"
      }
    },
    {
      "id": "alg-bits-subsets-012",
      "prompt": "Which tasks are performed when materializing one subset from a mask? Select all that apply.",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "multiple",
        "options": [
          {
            "id": "inspect_positions",
            "text": "Inspect the relevant n bit positions."
          },
          {
            "id": "test_membership",
            "text": "Test whether each mapped bit is set."
          },
          {
            "id": "append_selected",
            "text": "Append selected elements to the output subset."
          },
          {
            "id": "sort_mask_bits",
            "text": "Sort bit positions before every membership test."
          }
        ],
        "acceptedOptionIds": [
          "inspect_positions",
          "test_membership",
          "append_selected"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Decoding maps positional membership into a concrete subset.",
        "details": "No sorting is needed when the bit-to-index mapping is fixed.",
        "wrongOptionExplanationsByOptionId": {
          "sort_mask_bits": "Positions already have a fixed order."
        },
        "omittedCorrectExplanationsByOptionId": {
          "inspect_positions": "Each position may select one element.",
          "test_membership": "The bit determines inclusion.",
          "append_selected": "Materialization creates the represented values."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "enumerate_subset_by_bitmask",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "subset_mask",
        "problemArchetypeId": "enumerate_subsets_by_mask"
      }
    },
    {
      "id": "alg-bits-subsets-013",
      "prompt": "Which statements distinguish index subsets from value-distinct subsets? Select all that apply.",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "multiple",
        "options": [
          {
            "id": "indices_independent",
            "text": "Equal-valued input positions still correspond to different mask bits."
          },
          {
            "id": "duplicate_outputs",
            "text": "Different masks can materialize equal value sequences when input values repeat."
          },
          {
            "id": "needs_dedup_contract",
            "text": "Producing only value-distinct subsets requires an additional duplicate-control contract."
          },
          {
            "id": "masks_merge_equal",
            "text": "Equal values automatically share one mask bit."
          }
        ],
        "acceptedOptionIds": [
          "indices_independent",
          "duplicate_outputs",
          "needs_dedup_contract"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Bitmask enumeration is exact for indexed power sets.",
        "details": "Value-level uniqueness is a separate semantic layer.",
        "wrongOptionExplanationsByOptionId": {
          "masks_merge_equal": "Each indexed position has its own bit."
        },
        "omittedCorrectExplanationsByOptionId": {
          "indices_independent": "Masks encode occurrence identity.",
          "duplicate_outputs": "Value equality can collapse distinct index choices.",
          "needs_dedup_contract": "Plain masks do not infer it."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "enumerate_subset_by_bitmask",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "subset_mask",
        "problemArchetypeId": "enumerate_subsets_by_mask"
      }
    },
    {
      "id": "alg-bits-subsets-014",
      "prompt": "Arrange the outer algorithm for enumerating every subset mask.",
      "difficulty": "foundational",
      "interaction": {
        "type": "ordering",
        "elements": [
          {
            "id": "compute_limit",
            "text": "Compute the exclusive limit 2^n."
          },
          {
            "id": "initialize_mask",
            "text": "Start mask at 0."
          },
          {
            "id": "decode_mask",
            "text": "Decode the current mask into its subset."
          },
          {
            "id": "increment",
            "text": "Increment mask and repeat while mask is below the limit."
          }
        ],
        "canonicalOrder": [
          "compute_limit",
          "initialize_mask",
          "decode_mask",
          "increment"
        ],
        "scoringMethod": "adjacent_relations"
      },
      "scoringContract": {
        "type": "ordering",
        "maxPoints": 3
      },
      "feedback": {
        "reason": "The half-open mask range [0, 2^n) includes every n-bit pattern exactly once.",
        "details": "Starting at zero and stopping before the limit preserves both boundaries."
      },
      "taxonomy": {
        "primarySkillAtomId": "enumerate_subset_by_bitmask",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "subset_mask",
        "problemArchetypeId": "enumerate_subsets_by_mask"
      }
    },
    {
      "id": "alg-bits-subsets-015",
      "prompt": "Arrange the steps for decoding one mask into an ordered subset.",
      "difficulty": "foundational",
      "interaction": {
        "type": "ordering",
        "elements": [
          {
            "id": "initialize_subset",
            "text": "Initialize an empty output subset."
          },
          {
            "id": "iterate_indices",
            "text": "Iterate element indices from 0 through n - 1."
          },
          {
            "id": "test_bit",
            "text": "Test bit i in mask."
          },
          {
            "id": "append_if_set",
            "text": "Append elements[i] when the bit is set."
          }
        ],
        "canonicalOrder": [
          "initialize_subset",
          "iterate_indices",
          "test_bit",
          "append_if_set"
        ],
        "scoringMethod": "adjacent_relations"
      },
      "scoringContract": {
        "type": "ordering",
        "maxPoints": 3
      },
      "feedback": {
        "reason": "The decoding order follows element indices, while membership follows mask bits.",
        "details": "This produces a stable index-ordered materialization."
      },
      "taxonomy": {
        "primarySkillAtomId": "enumerate_subset_by_bitmask",
        "secondarySkillAtomIds": [],
