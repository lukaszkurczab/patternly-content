    {
      "id": "alg-bits-xor-008",
      "prompt": "Can equal negative integers cancel under fixed-width two's-complement XOR?",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "yes_same_pattern",
            "text": "Yes. Equal negative integers have identical fixed-width bit patterns, and x XOR x is zero."
          },
          {
            "id": "no_sign",
            "text": "No. Sign bits can never cancel."
          },
          {
            "id": "only_positive",
            "text": "XOR cancellation works only for positive values."
          },
          {
            "id": "only_unsigned",
            "text": "The operands must be reinterpreted as unsigned numeric values first."
          }
        ],
        "acceptedOptionIds": [
          "yes_same_pattern"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Self-cancellation depends on equality of bit patterns, not on numeric sign.",
        "details": "The width must still be fixed so both patterns are comparable position by position.",
        "wrongOptionExplanationsByOptionId": {
          "no_sign": "Equal sign bits XOR to zero like every other equal bit.",
          "only_positive": "The identity is bit-pattern based.",
          "only_unsigned": "The stored bits can be XORed directly."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "apply_xor_cancellation",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "xor_cancellation",
        "problemArchetypeId": "find_unique_element"
      },
      "constraints": [
        "All values use the same fixed-width two's-complement representation."
      ]
    },
    {
      "id": "alg-bits-xor-009",
      "prompt": "Which multiplicity contract is required for the basic one-unique XOR solution?",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "all_pairs_one_single",
            "text": "Every non-answer value occurs an even canceling number of times, typically exactly twice, and the answer occurs an odd number of times."
          },
          {
            "id": "arbitrary_counts",
            "text": "Every value may occur any number of times with no further structure."
          },
          {
            "id": "sorted_only",
            "text": "The values must be sorted."
          },
          {
            "id": "positive_only",
            "text": "Every value must be positive."
          }
        ],
        "acceptedOptionIds": [
          "all_pairs_one_single"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "The algorithm isolates one odd-frequency pattern only under a matching multiplicity guarantee.",
        "details": "Without that contract, the aggregate XOR may represent several uncancelled values combined.",
        "wrongOptionExplanationsByOptionId": {
          "arbitrary_counts": "Multiple odd-frequency values would combine into an unrelated XOR.",
          "sorted_only": "Order is irrelevant.",
          "positive_only": "Equal fixed-width negative patterns cancel too."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "apply_xor_cancellation",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "xor_cancellation",
        "problemArchetypeId": "find_unique_element"
      }
    },
