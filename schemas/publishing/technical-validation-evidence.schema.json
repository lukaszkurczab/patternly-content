{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "technical-validation-evidence-v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["evidenceSchemaVersion", "canonicalSerializationVersion", "validatorVersion", "trackId", "familyId", "batchId", "sourceCommit", "sourceTreeFingerprint", "batchFingerprint", "itemFingerprints", "result", "diagnosticCodes", "evidenceId"],
  "properties": { "evidenceSchemaVersion": { "const": 1 }, "canonicalSerializationVersion": { "const": "canonical-json-v1" }, "validatorVersion": { "type": "string", "minLength": 1 }, "trackId": { "type": "string", "minLength": 1 }, "familyId": { "type": "string", "minLength": 1 }, "batchId": { "type": "string", "minLength": 1 }, "sourceCommit": { "type": "string", "minLength": 1 }, "sourceTreeFingerprint": { "type": "string", "minLength": 1 }, "batchFingerprint": { "type": "string", "minLength": 1 }, "itemFingerprints": { "type": "object" }, "result": { "enum": ["passed", "failed"] }, "diagnosticCodes": { "type": "array", "items": { "type": "string" } }, "evidenceId": { "type": "string", "minLength": 1 } }
}
