      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "parity",
            "text": "Whether that bit is set in an odd number of inputs."
          },
          {
            "id": "count",
            "text": "The exact number of set occurrences."
          },
          {
            "id": "maximum",
            "text": "The largest bit position seen."
          },
          {
            "id": "union",
            "text": "Whether the bit is set in at least one input."
          }
