  "items": [
    {
      "id": "alg-bits-manipulate-001",
      "prompt": "Which expression tests whether zero-based bit k is set in x?",
      "difficulty": "intro",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "and_nonzero",
            "text": "(x AND (1 shifted left by k)) is nonzero."
          },
          {
            "id": "or_nonzero",
            "text": "(x OR (1 shifted left by k)) is nonzero."
          },
          {
            "id": "xor_zero",
            "text": "(x XOR (1 shifted left by k)) is zero."
          },
          {
            "id": "add_mask",
            "text": "x + (1 shifted left by k)."
          }
        ],
        "acceptedOptionIds": [
          "and_nonzero"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "AND preserves the selected bit only when it is set in both x and the one-hot mask.",
        "details": "A nonzero result therefore means bit k was one.",
        "wrongOptionExplanationsByOptionId": {
          "or_nonzero": "OR makes the selected bit one even if it was previously zero.",
          "xor_zero": "XOR changes the bit rather than directly testing its prior state.",
          "add_mask": "Addition can affect multiple bits through carries."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "manipulate_selected_bit",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "bit_mask",
        "problemArchetypeId": "encode_boolean_state"
      }
    },
    {
      "id": "alg-bits-manipulate-002",
      "prompt": "Which operation sets every bit selected by mask without clearing unselected bits?",
      "difficulty": "intro",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "or_mask",
            "text": "x OR mask."
          },
          {
            "id": "and_mask",
            "text": "x AND mask."
          },
          {
            "id": "xor_mask",
            "text": "x XOR mask."
          },
          {
            "id": "and_not_mask",
            "text": "x AND complement(mask)."
          }
        ],
        "acceptedOptionIds": [
          "or_mask"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "OR forces selected positions to one and leaves every zero-mask position unchanged.",
        "details": "This works for one-hot and multi-bit masks.",
        "wrongOptionExplanationsByOptionId": {
          "and_mask": "AND clears unselected bits rather than preserving them.",
          "xor_mask": "XOR toggles selected bits and may clear ones.",
          "and_not_mask": "This clears selected bits."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "manipulate_selected_bit",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "bit_mask",
        "problemArchetypeId": "encode_boolean_state"
      }
    },
    {
      "id": "alg-bits-manipulate-003",
      "prompt": "Using a width-limited complement, which operation clears every bit selected by mask?",
      "difficulty": "intro",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "and_not_mask",
            "text": "x AND complement(mask)."
          },
          {
            "id": "or_mask",
            "text": "x OR mask."
          },
          {
            "id": "xor_mask",
            "text": "x XOR mask."
          },
          {
            "id": "and_mask",
            "text": "x AND mask."
          }
        ],
        "acceptedOptionIds": [
          "and_not_mask"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Complement(mask) has zeros at selected positions and ones elsewhere within the declared width.",
        "details": "AND therefore clears only those selected positions.",
        "wrongOptionExplanationsByOptionId": {
          "or_mask": "OR sets the selected positions.",
          "xor_mask": "XOR toggles rather than guarantees zero.",
          "and_mask": "This keeps selected bits and clears unselected bits."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "manipulate_selected_bit",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "bit_mask",
        "problemArchetypeId": "encode_boolean_state"
      },
      "constraints": [
        "Complement is limited to the declared storage width."
      ]
    },
    {
      "id": "alg-bits-manipulate-004",
      "prompt": "Which operation toggles every bit selected by mask?",
      "difficulty": "intro",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "xor_mask",
            "text": "x XOR mask."
          },
          {
            "id": "or_mask",
            "text": "x OR mask."
          },
          {
            "id": "and_mask",
            "text": "x AND mask."
          },
          {
            "id": "and_not_mask",
            "text": "x AND complement(mask)."
          }
        ],
        "acceptedOptionIds": [
          "xor_mask"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "XOR with one flips a bit, while XOR with zero preserves it.",
        "details": "A mask therefore selects exactly the positions to toggle.",
        "wrongOptionExplanationsByOptionId": {
          "or_mask": "OR cannot turn a selected one into zero.",
          "and_mask": "AND does not invert selected positions.",
          "and_not_mask": "This always clears selected positions."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "manipulate_selected_bit",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "bit_mask",
        "problemArchetypeId": "encode_boolean_state"
      }
    },
    {
      "id": "alg-bits-manipulate-005",
      "prompt": "What happens if the same set operation x = x OR mask is applied twice?",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "same_after_first",
            "text": "The second application makes no additional change."
          },
          {
            "id": "toggles_off",
            "text": "The selected bits are cleared by the second application."
          },
          {
            "id": "adds_mask",
            "text": "The numeric value increases by mask again."
          },
          {
            "id": "clears_others",
            "text": "All unselected bits are cleared."
          }
        ],
        "acceptedOptionIds": [
          "same_after_first"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Setting selected bits is idempotent.",
        "details": "Once the mask's one positions are already set, OR with the same mask leaves the word unchanged.",
        "wrongOptionExplanationsByOptionId": {
          "toggles_off": "OR is not toggle.",
          "adds_mask": "Bitwise OR is idempotent.",
          "clears_others": "Zero mask positions preserve x."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "manipulate_selected_bit",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "bit_mask",
        "problemArchetypeId": "encode_boolean_state"
      }
    },
    {
      "id": "alg-bits-manipulate-006",
      "prompt": "What happens if the same clear operation x = x AND complement(mask) is applied twice?",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "same_after_first",
            "text": "The second application makes no additional change."
          },
          {
            "id": "sets_again",
            "text": "The selected bits become one again."
          },
          {
            "id": "clears_all",
            "text": "The second application clears every bit."
          },
          {
            "id": "increments",
            "text": "The value increases by mask."
          }
        ],
        "acceptedOptionIds": [
          "same_after_first"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Clearing selected bits is idempotent.",
        "details": "After the first application, every selected position is already zero.",
        "wrongOptionExplanationsByOptionId": {
          "sets_again": "Clearing is not toggle.",
          "clears_all": "Unselected positions remain protected by ones in the complemented mask.",
          "increments": "AND does not perform addition."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "manipulate_selected_bit",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "bit_mask",
        "problemArchetypeId": "encode_boolean_state"
      },
      "constraints": [
        "Complement is limited to the declared storage width."
      ]
    },
    {
      "id": "alg-bits-manipulate-007",
      "prompt": "What is the effect of toggling the same mask twice?",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "restores_original",
            "text": "The original word is restored."
          },
          {
            "id": "sets_mask",
            "text": "The selected bits remain set."
          },
          {
            "id": "clears_mask",
            "text": "The selected bits remain clear."
          },
          {
            "id": "reverses_bits",
            "text": "All bit positions are reversed."
          }
        ],
        "acceptedOptionIds": [
          "restores_original"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "XOR is self-inverse for a fixed mask.",
        "details": "(x XOR mask) XOR mask equals x because mask XOR mask is zero.",
        "wrongOptionExplanationsByOptionId": {
          "sets_mask": "That is the behavior of OR, not two XOR operations.",
          "clears_mask": "Two toggles cancel regardless of initial state.",
          "reverses_bits": "XOR does not reorder positions."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "manipulate_selected_bit",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "bit_mask",
        "problemArchetypeId": "encode_boolean_state"
      }
    },
    {
      "id": "alg-bits-manipulate-008",
      "prompt": "Which expression tests whether all bits selected by mask are already set in x?",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "and_equals_mask",
            "text": "(x AND mask) equals mask."
          },
          {
            "id": "and_nonzero",
            "text": "(x AND mask) is nonzero."
          },
          {
            "id": "or_equals_zero",
            "text": "(x OR mask) equals zero."
          },
          {
            "id": "xor_equals_mask",
            "text": "(x XOR mask) equals mask."
          }
        ],
        "acceptedOptionIds": [
          "and_equals_mask"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "AND extracts the selected positions from x.",
        "details": "Equality with mask means every one required by the mask was present.",
        "wrongOptionExplanationsByOptionId": {
          "and_nonzero": "This proves at least one selected bit is set, not all.",
          "or_equals_zero": "OR with a nonzero mask cannot produce zero.",
          "xor_equals_mask": "This does not directly express all-selected membership."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "manipulate_selected_bit",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "bit_mask",
        "problemArchetypeId": "encode_boolean_state"
      }
    },
    {
      "id": "alg-bits-manipulate-009",
      "prompt": "Which expression tests whether at least one bit selected by mask is set in x?",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "and_nonzero",
            "text": "(x AND mask) is nonzero."
          },
          {
            "id": "and_equals_mask",
            "text": "(x AND mask) equals mask."
          },
          {
            "id": "or_equals_x",
            "text": "(x OR mask) equals x."
          },
          {
            "id": "xor_zero",
            "text": "(x XOR mask) is zero."
          }
        ],
        "acceptedOptionIds": [
          "and_nonzero"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Any shared one position survives AND and makes the result nonzero.",
        "details": "This is an overlap test rather than an all-required test.",
        "wrongOptionExplanationsByOptionId": {
          "and_equals_mask": "That requires all selected bits.",
          "or_equals_x": "That also means all selected bits are already set.",
          "xor_zero": "That means x equals mask over every position, not merely overlap."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "manipulate_selected_bit",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "bit_mask",
        "problemArchetypeId": "encode_boolean_state"
      }
    },
    {
      "id": "alg-bits-manipulate-010",
      "prompt": "An 8-bit word is 10101100 and mask is 00001100. What is the result of clearing the selected mask bits?",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "single",
        "options": [
          {
            "id": "bits_10100000",
            "text": "10100000."
          },
          {
            "id": "bits_10101100",
            "text": "10101100."
          },
          {
            "id": "bits_00001100",
            "text": "00001100."
          },
          {
            "id": "bits_10101111",
            "text": "10101111."
          }
        ],
        "acceptedOptionIds": [
          "bits_10100000"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "The mask selects bit positions 2 and 3, both of which become zero.",
        "details": "All other positions remain unchanged.",
        "wrongOptionExplanationsByOptionId": {
          "bits_10101100": "The selected low-middle bits would remain set.",
          "bits_00001100": "That extracts selected bits rather than clearing them.",
          "bits_10101111": "This sets low bits rather than clearing the mask positions."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "manipulate_selected_bit",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "bit_mask",
        "problemArchetypeId": "encode_boolean_state"
      },
      "constraints": [
        "Use exactly 8 bits for complement and results."
      ]
    },
    {
      "id": "alg-bits-manipulate-011",
      "prompt": "Which identities are correct for a fixed-width word x and mask m? Select all that apply.",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "multiple",
        "options": [
          {
            "id": "set_idempotent",
            "text": "(x OR m) OR m equals x OR m."
          },
          {
            "id": "clear_idempotent",
            "text": "(x AND complement(m)) AND complement(m) equals x AND complement(m)."
          },
          {
            "id": "toggle_twice",
            "text": "(x XOR m) XOR m equals x."
          },
          {
            "id": "toggle_idempotent",
            "text": "(x XOR m) XOR m equals x XOR m."
          }
        ],
        "acceptedOptionIds": [
          "set_idempotent",
          "clear_idempotent",
          "toggle_twice"
        ]
      },
      "scoringContract": {
        "type": "choice",
        "resultSemantics": "exact_selected_set_with_partial_v1"
      },
      "feedback": {
        "reason": "Set and clear are idempotent, while toggle is self-inverse.",
        "details": "These algebraic properties help diagnose incorrect operation selection.",
        "wrongOptionExplanationsByOptionId": {
          "toggle_idempotent": "Two toggles restore x rather than preserve the once-toggled state."
        },
        "omittedCorrectExplanationsByOptionId": {
          "set_idempotent": "OR with the same mask is idempotent.",
          "clear_idempotent": "Clearing the same positions twice has no extra effect.",
          "toggle_twice": "XOR with the same mask cancels."
        }
      },
      "taxonomy": {
        "primarySkillAtomId": "manipulate_selected_bit",
        "secondarySkillAtomIds": [],
        "learningStage": "pattern_mechanics",
        "patternVariantId": "bit_mask",
        "problemArchetypeId": "encode_boolean_state"
      },
      "constraints": [
        "Complement is width-limited."
      ]
    },
    {
      "id": "alg-bits-manipulate-012",
      "prompt": "Which operations preserve every bit position where mask has zero? Select all that apply.",
      "difficulty": "foundational",
      "interaction": {
        "type": "choice",
        "selectionMode": "multiple",
        "options": [
          {
            "id": "or_mask",
            "text": "x OR mask."
          },
          {
            "id": "xor_mask",
            "text": "x XOR mask."
          },
          {
            "id": "and_not_mask",
